@page "/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components.Authorization
@using AntalyaStation.Client.Handlers
@rendermode InteractiveServer
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="login-container" style="max-width: 400px; margin: 100px auto; padding: 30px; border: 1px solid #333; border-radius: 12px; background-color: #1e1e1e; color: white; box-shadow: 0 10px 25px rgba(0,0,0,0.5);">
    <h3 style="margin-bottom: 25px; text-align: center; color: #007bff;">AntalyaStation</h3>
    <h5 style="margin-bottom: 25px; text-align: center; font-weight: 300;">Yönetim Paneli Girişi</h5>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" style="background-color: #4a1d1d; color: #ff8e8e; border: 1px solid #ff6b6b; padding: 10px; border-radius: 4px; margin-bottom: 15px; text-align: center;">
            @errorMessage
        </div>
    }

    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="LoginForm">
        <DataAnnotationsValidator />
        
        <div class="form-group" style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px; color: #ccc;">Kullanıcı Adı:</label>
            <InputText @bind-Value="loginModel.Username" class="form-control" style="width: 100%; padding: 10px; background-color: #2d2d2d; color: white; border: 1px solid #444; border-radius: 6px;" />
        </div>

        <div class="form-group" style="margin-bottom: 25px;">
            <label style="display: block; margin-bottom: 5px; color: #ccc;">Şifre:</label>
            <InputText @bind-Value="loginModel.Password" type="password" class="form-control" style="width: 100%; padding: 10px; background-color: #2d2d2d; color: white; border: 1px solid #444; border-radius: 6px;" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isLoading" style="width: 100%; padding: 12px; background-color: #007bff; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 16px;">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span> Giriş yapılıyor...</span>
            }
            else
            {
                <span>Giriş Yap</span>
            }
        </button>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm]
    public LoginDto loginModel { get; set; } = new LoginDto();
    
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResultDto>(
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    var customProvider = (CustomAuthStateProvider)AuthStateProvider;
                    await customProvider.MarkUserAsAuthenticated(result.Token);
                    Navigation.NavigateTo("/");
                }
                else
                {
                    errorMessage = "Giriş başarılı ama token alınamadı (deserialization sorunu).";
                }
            }
            else
            {
                var errorData = await response.Content.ReadFromJsonAsync<ErrorResponse>(
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = errorData?.Message ?? "Giriş işlemi başarısız oldu.";
            }
        }
      /*  catch (Exception ex)
        {
            errorMessage = $"HATA: {ex.GetType().Name} - {ex.Message}";
        }
        */catch (Exception)
        {
            errorMessage = "Sunucuya bağlanılamadı. Lütfen API'nin çalıştığından emin olun.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginDto
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    public class LoginResultDto
    {
        public string Token { get; set; } = string.Empty;
    }

    public class ErrorResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}