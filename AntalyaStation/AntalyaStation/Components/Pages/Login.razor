@page "/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations
@using AntalyaStation.Client.Handlers
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="login-card">
    <div class="login-header">
        <h2 class="brand-title">AntalyaStation</h2>
        <p class="brand-subtitle">Enterprise Data & Analytics Console</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert-banner">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        </div>
    }

    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="LoginForm">
        <DataAnnotationsValidator />
        
        <div class="form-field">
            <label class="field-label">Username</label>
            <div class="input-wrapper">
                <i class="bi bi-person field-icon"></i>
                <InputText @bind-Value="loginModel.Username" class="custom-control" placeholder="Enter your corporate ID" />
            </div>
            <ValidationMessage For="@(() => loginModel.Username)" class="text-danger small mt-1" />
        </div>

        <div class="form-field">
            <label class="field-label">Password</label>
            <div class="input-wrapper">
                <i class="bi bi-lock field-icon"></i>
                <InputText @bind-Value="loginModel.Password" type="password" class="custom-control" placeholder="Enter security credentials" />
            </div>
            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger small mt-1" />
        </div>

        <button type="submit" class="btn-submit" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Authenticating...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>
    </EditForm>
</div>

<style>
    .login-card {
        width: 100%;
        max-width: 440px;
        padding: 40px;
        background: rgba(30, 30, 30, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }
    .brand-title {
        font-weight: 800;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, #fff 0%, #007bff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-align: center;
        margin-bottom: 4px;
    }
    .brand-subtitle {
        color: #888;
        font-size: 0.9rem;
        text-align: center;
        margin-bottom: 30px;
    }
    .alert-banner {
        background-color: rgba(220, 53, 69, 0.15);
        border: 1px solid rgba(220, 53, 69, 0.4);
        color: #ff808b;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 0.875rem;
    }
    .form-field {
        margin-bottom: 20px;
    }
    .field-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #aaa;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }
    .field-icon {
        position: absolute;
        left: 14px;
        color: #666;
        font-size: 1.1rem;
    }
    .custom-control {
        width: 100%;
        padding: 12px 14px 12px 42px;
        background-color: rgba(0, 0, 0, 0.2);
        color: #fff;
        border: 1px solid #444;
        border-radius: 8px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .custom-control:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.25);
    }
    .btn-submit {
        width: 100%;
        padding: 14px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 1rem;
        transition: background-color 0.2s ease, transform 0.1s ease;
        margin-top: 10px;
    }
    .btn-submit:hover:not(:disabled) {
        background-color: #0069d9;
    }
    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>

@code {
    [SupplyParameterFromForm]
    public LoginDto loginModel { get; set; } = new LoginDto();
    
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResultDto>(
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    // 💡 Uses your CustomAuthStateProvider to handle state updates
                    var customProvider = (CustomAuthStateProvider)AuthStateProvider;
                    await customProvider.MarkUserAsAuthenticated(result.Token);
                    Navigation.NavigateTo("/");
                }
                else
                {
                    errorMessage = "Authentication succeeded, but the API secure token failed to load.";
                }
            }
            else
            {
                var errorData = await response.Content.ReadFromJsonAsync<ErrorResponse>(
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                errorMessage = errorData?.Message ?? "Invalid credentials. Please verify your access privileges.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Unable to establish connection with security server. Please ensure the API layer is active.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginDto
    {
        [Required(ErrorMessage = "Username context is required.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password configuration is required.")]
        public string Password { get; set; } = string.Empty;
    }

    public class LoginResultDto
    {
        public string Token { get; set; } = string.Empty;
    }

    public class ErrorResponse
    {
        public string Message { get; set; } = string.Empty;
    }
}