@page "/view-data"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Net.Http.Json
@using AntalyaStation.API.DTOs
@using BlazorBootstrap
@inject HttpClient Http
@inject IJSRuntime JsRuntime

<style>
    .hide-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }

    .vd-header {
        background: linear-gradient(135deg, #0d47a1 0%, #1976d2 60%, #00acc1 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 8px 24px rgba(13,71,161,0.2);
    }
    .vd-header h3 { font-weight: 800; margin-bottom: 4px; }
    .vd-header p { opacity: 0.9; margin-bottom: 0; font-size: 14px; }

    .vd-filter-card { border-radius: 14px; border: none; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .vd-filter-card .form-label { font-size: 12px; font-weight: 700; color: #495057; text-transform: uppercase; letter-spacing: 0.3px; }
    .vd-filter-card .form-control, .vd-filter-card .form-select { font-size: 13px; border-radius: 8px; }

    .vd-table-card { border-radius: 14px; border: none; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .vd-table-card table { font-size: 13px; }
    .vd-table-card thead th { background: #f8f9fb; font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; color: #6c757d; }

    .status-pill { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .status-public { background: #e6f7ee; color: #16794e; }
    .status-private { background: #fff3e0; color: #b8630b; }
    .status-none { background: #fdeaea; color: #c0392b; }
</style>

<div class="container-fluid mt-3" style="font-size: 13px;">

    <!-- HEADER -->
    <div class="vd-header">
        <h3><i class="bi bi-database-fill-check"></i> Charging Station Repository</h3>
        <p>Search, filter, and inspect all registered charging stations across the network.</p>
    </div>

    <!-- FILTER PANEL -->
    <div class="card vd-filter-card mb-3">
        <div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label d-block mb-1">Search</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white py-0 px-2"><i class="bi bi-search text-primary" style="font-size: 12px;"></i></span>
                        <input type="text" class="form-control form-control-sm" @bind="_filter.SearchText"
                               placeholder="Station name, number, brand...">
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label d-block mb-1">District</label>
                    <select class="form-select form-select-sm" @bind="_filter.District">
                        <option value="Any">All Districts</option>
                        @foreach (var district in _allDistricts)
                        {
                            <option value="@district">@district</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label d-block mb-1">Service Type</label>
                    <select class="form-select form-select-sm" @bind="_filter.ServiceType">
                        <option value="Any">Any</option>
                        <option value="Public">Public</option>
                        <option value="Private">Private</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-primary btn-sm flex-grow-1 fw-semibold" style="height: 33px;" @onclick="ExecuteQuery">
                        <i class="bi bi-search"></i> Run Query
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" style="height: 33px;" @onclick="ClearFilters">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                </div>
            </div>

            <!-- ADVANCED CRITERIA -->
            <div class="accordion accordion-flush mt-2" id="advancedFilterAccordion">
                <div class="accordion-item border-0 bg-transparent">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed ps-0 py-1 text-primary fw-semibold" style="font-size: 12px; background: transparent !important;" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne">
                            <i class="bi bi-sliders me-1"></i> Advanced Settings
                        </button>
                    </h2>
                    <div id="flush-collapseOne" class="accordion-collapse collapse" data-bs-parent="#advancedFilterAccordion">
                        <div class="accordion-body p-2">
                            <div class="row g-2 align-items-center">
                                <div class="col-md-2">
                                    <select class="form-select form-select-sm" @bind="_filter.StationType">
                                        <option value="Any">Type: Any</option>
                                        <option value="AC">AC</option>
                                        <option value="DC">DC</option>
                                    </select>
                                </div>
                                @if (_hasPassiveStations)
                                {
                                    <div class="col-md-3 form-check m-0">
                                        <input type="checkbox" class="form-check-input" id="inactiveFilter" checked="@_filter.IncludeInactive" @onchange="OnIncludeInactiveChanged">
                                        <label class="form-check-label text-muted fw-semibold" style="font-size: 12px;" for="inactiveFilter">Show passive</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card vd-table-card">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div>
                    <h5 class="fw-bold m-0 text-dark">Station Records</h5>
                    <span class="text-muted small">Click a column header to sort.</span>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <div class="d-flex align-items-center gap-1 bg-light p-1 rounded border" style="height: 33px;">
                        <label class="small text-muted fw-bold m-0 text-nowrap px-1" style="font-size: 11px;">Show:</label>
                        <select class="form-select form-select-sm border-0 bg-transparent fw-bold text-primary py-0" style="width: 65px; font-size: 12px;" value="@_pageSize" @onchange="OnPageSizeChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                    <Button Color="ButtonColor.Info" Size="ButtonSize.Small" Class="text-white py-1 fw-semibold" Style="height: 33px; font-size: 12px;" @onclick="ExportToExcel">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </Button>
                </div>
            </div>

            <Grid @ref="grid" TItem="StationDto" DataProvider="StationsDataProvider" AllowPaging="true" PageSize="@_pageSize" Class="table table-hover table-bordered text-center align-middle mb-0" Responsive="true">
                <GridColumns>
                    <GridColumn TItem="StationDto" HeaderText="Station No" PropertyName="StationNumber" Sortable="true">@context.StationNumber</GridColumn>
                    <GridColumn TItem="StationDto" HeaderText="Station Name" PropertyName="StationName" Sortable="true" Class="fw-semibold text-start">@context.StationName</GridColumn>

                    <GridColumn TItem="StationDto" HeaderText="Service Type" Sortable="false">
                        @{
                            var badgeClass = GetServiceBadgeClass(context.ServiceType);
                            var badgeText = GetServiceBadgeText(context.ServiceType);
                        }
                        <span class="status-pill @badgeClass">@badgeText</span>
                    </GridColumn>

                    <GridColumn TItem="StationDto" HeaderText="Brand" PropertyName="Brand" Sortable="true">@context.Brand</GridColumn>
                    <GridColumn TItem="StationDto" HeaderText="Network" PropertyName="OperatorNetwork" Sortable="true">@context.OperatorNetwork</GridColumn>
                    <GridColumn TItem="StationDto" HeaderText="Added Date" PropertyName="AddedDate" Sortable="true">@context.AddedDate.ToString("yyyy-MM-dd")</GridColumn>
                    <GridColumn TItem="StationDto" HeaderText="kW" PropertyName="Power" Sortable="true">@context.TotalPower</GridColumn>

                    <GridColumn TItem="StationDto" HeaderText="Status" Sortable="false">
                        <span class="badge @(context.Status == "Inactive" ? "bg-secondary" : "bg-success")">@context.Status</span>
                        @if (context.DeactivatedDate.HasValue)
                        {
                            <div class="text-muted" style="font-size: 11px;">@context.DeactivatedDate.Value.ToString("yyyy-MM-dd")</div>
                        }
                    </GridColumn>

                    <GridColumn TItem="StationDto" HeaderText="Sockets" PropertyName="SocketCount" Sortable="true">
                        <div class="d-flex align-items-center justify-content-center gap-1">
                            <span class="badge bg-primary px-2 py-1" style="font-size: 11px;">@context.SocketCount pcs</span>
                            <button type="button" class="btn btn-xs btn-info text-white px-1 py-0" style="font-size: 11px;" @onclick="() => OpenSocketDetails(context)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </GridColumn>

                    <GridColumn TItem="StationDto" HeaderText="Full Address" Sortable="false" Class="text-start">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="fw-semibold text-dark" style="font-size: 12px;">
                                @context.City @(string.IsNullOrEmpty(context.District) ? "" : $"/ {context.District}")
                            </div>
                            @if (!string.IsNullOrEmpty(context.Address))
                            {
                                <button type="button" class="btn btn-link p-0 m-0 lh-1 text-decoration-none shadow-none"
                                        @onclick="() => CopyToClipboard(context.Address)"
                                        title="Copy Full Address">
                                    <i class="bi bi-clipboard text-muted" style="font-size: 13px; cursor: pointer;" onmouseover="this.className='bi bi-clipboard-fill text-primary'" onmouseout="this.className='bi bi-clipboard text-muted'"></i>
                                </button>
                            }
                        </div>
                        <div class="hide-scrollbar"
                             style="max-width: 250px; overflow-x: auto; white-space: nowrap; font-size: 12px; color: #6c757d; line-height: 1.3; cursor: text;"
                             title="@context.Address">
                            @context.Address
                        </div>
                    </GridColumn>
                </GridColumns>
            </Grid>
        </div>
    </div>
</div>

<!-- 🔌 SOCKET DETAILS MODAL -->
<Modal @ref="socketDetailsModal" Title="🔌 Socket Configuration" IsVerticallyCentered="true">
    <BodyTemplate>
        @if (selectedStationForSockets != null)
        {
            <div class="mb-3">
                <h6 class="fw-bold text-primary">@selectedStationForSockets.StationName</h6>
                <small class="text-muted">Station No: @selectedStationForSockets.StationNumber</small>
            </div>

            <table class="table table-sm table-striped table-bordered text-center align-middle small">
                <thead class="table-dark">
                <tr>
                    <th>Socket No</th>
                    <th>Type</th>
                    <th>Power (kW)</th>
                </tr>
                </thead>
                <tbody>
                @if (selectedStationForSockets.Sockets != null && selectedStationForSockets.Sockets.Any())
                {
                    @foreach (var socket in selectedStationForSockets.Sockets)
                    {
                        <tr>
                            <td class="fw-bold">@socket.SocketNumber</td>
                            <td><span class="badge bg-secondary">@socket.Type</span></td>
                            <td class="text-success fw-bold">@socket.Power kW</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-muted py-2">No sockets found.</td>
                    </tr>
                }
                </tbody>
            </table>
        }
        <div class="d-flex justify-content-end mt-3">
            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="CloseSocketModal">Close</Button>
        </div>
    </BodyTemplate>
</Modal>

@code {
    private Grid<StationDto> grid = default!;
    private Modal socketDetailsModal = default!;
    private StationDto? selectedStationForSockets;

    private string apiBaseUrl = "http://localhost:5079";

    private int _pageSize = 10;
    private List<StationDto> allCurrentData = new();

    private StationFilterDto _filter = new() { District = "Any", ServiceType = "Any", StationType = "Any" };

    // Flat, city-agnostic district list (no city filter — district only)
    private List<string> _allDistricts = new();

    // Only show the "Show passive" toggle when passive stations actually exist
    private bool _hasPassiveStations = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDistricts();
        await CheckPassiveStationsExist();
    }

    private async Task LoadDistricts()
    {
        try
        {
            var cities = await Http.GetFromJsonAsync<List<string>>($"{apiBaseUrl}/api/stations/cities");
            var districtSet = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            foreach (var city in cities ?? new List<string>())
            {
                var districts = await Http.GetFromJsonAsync<List<string>>(
                    $"{apiBaseUrl}/api/stations/cities/{Uri.EscapeDataString(city)}/districts");

                foreach (var d in districts ?? new List<string>())
                    districtSet.Add(d);
            }

            _allDistricts = districtSet.OrderBy(d => d).ToList();
        }
        catch
        {
            _allDistricts = new List<string>();
        }
    }

    private async Task CheckPassiveStationsExist()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<DashboardStatsDto>($"{apiBaseUrl}/api/stations/dashboard-stats");
            _hasPassiveStations = (stats?.TotalInactiveStations ?? 0) > 0;
        }
        catch
        {
            _hasPassiveStations = false;
        }

        if (!_hasPassiveStations)
        {
            _filter.IncludeInactive = false;
        }
    }

    private string GetServiceBadgeClass(string? serviceType)
    {
        var v = serviceType?.ToUpper() ?? "";
        if (string.IsNullOrWhiteSpace(v)) return "status-none";
        if (v.Contains("HALKA") || v.Contains("ACIK") || v.Contains("PUBLIC")) return "status-public";
        if (v.Contains("OZEL") || v.Contains("ÖZEL") || v.Contains("PRIVATE")) return "status-private";
        return "status-none";
    }

    private string GetServiceBadgeText(string? serviceType)
    {
        var v = serviceType?.ToUpper() ?? "";
        if (string.IsNullOrWhiteSpace(v)) return "Not Provided";
        if (v.Contains("HALKA") || v.Contains("ACIK") || v.Contains("PUBLIC")) return "Public";
        if (v.Contains("OZEL") || v.Contains("ÖZEL") || v.Contains("PRIVATE")) return "Private";
        return serviceType ?? "Unknown";
    }

    private async Task CopyToClipboard(string address)
    {
        if (!string.IsNullOrWhiteSpace(address))
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", address);
        }
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int size))
        {
            _pageSize = size;
            StateHasChanged();
            await Task.Delay(20);

            if (grid != null)
            {
                await grid.RefreshDataAsync();
            }
        }
    }

    private async Task ExecuteQuery()
    {
        if (grid != null) await grid.RefreshDataAsync();
    }

    private async Task OnIncludeInactiveChanged(ChangeEventArgs e)
    {
        _filter.IncludeInactive = e.Value is bool value && value;
        await ExecuteQuery();
    }

    private async Task ClearFilters()
    {
        _filter = new StationFilterDto { District = "Any", ServiceType = "Any", StationType = "Any", SearchText = "", IncludeInactive = false };

        if (grid != null) await grid.RefreshDataAsync();
    }

    // 🟢 Sorting artık ayrı butonlarla değil, kolon başlığına tıklayınca Grid'in kendi
    // sıralama mekanizmasından (request.Sorting) okunuyor.
    private async Task<GridDataProviderResult<StationDto>> StationsDataProvider(GridDataProviderRequest<StationDto> request)
    {
        try
        {
            string districtParam = _filter.District == "Any" ? "" : _filter.District;
            string serviceParam = _filter.ServiceType == "Any" ? "" : _filter.ServiceType;
            string typeParam = _filter.StationType == "Any" ? "" : _filter.StationType;

            var (sortBy, sortDirection) = ResolveSort(request);

            var url = $"{apiBaseUrl}/api/stations?pageNumber={request.PageNumber}&pageSize={request.PageSize}" +
                      $"&searchText={Uri.EscapeDataString(_filter.SearchText ?? "")}" +
                      $"&district={Uri.EscapeDataString(districtParam)}" +
                      $"&serviceType={Uri.EscapeDataString(serviceParam)}" +
                      $"&stationType={Uri.EscapeDataString(typeParam)}" +
                      $"&sortBy={Uri.EscapeDataString(sortBy)}" +
                      $"&sortDirection={Uri.EscapeDataString(sortDirection)}" +
                      $"&includeInactive={_filter.IncludeInactive.ToString().ToLowerInvariant()}";

            var response = await Http.GetFromJsonAsync<PagedResult<StationDto>>(url);
            if (response != null)
            {
                allCurrentData = response.Data;
                return new GridDataProviderResult<StationDto> { Data = response.Data, TotalCount = response.TotalCount };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Grid data link error: {ex.Message}");
        }
        return new GridDataProviderResult<StationDto> { Data = new List<StationDto>(), TotalCount = 0 };
    }

    // 🟢 Grid kütüphanesinin sürüm farklarına dayanıklı olmak için Sorting öğesindeki
    // alan adını reflection ile arıyoruz (PropertyName / SortString / SortLabel).
    private (string SortBy, string SortDirection) ResolveSort(GridDataProviderRequest<StationDto> request)
    {
        string sortBy = "stationName";
        string sortDirection = "asc";

        var activeSort = request.Sorting?.FirstOrDefault(s => s.SortDirection != SortDirection.None);
        if (activeSort != null)
        {
            var type = activeSort.GetType();
            var prop = type.GetProperty("PropertyName") ?? type.GetProperty("SortString") ?? type.GetProperty("SortLabel");
            if (prop != null)
            {
                sortBy = prop.GetValue(activeSort)?.ToString() ?? sortBy;
            }
            sortDirection = activeSort.SortDirection == SortDirection.Descending ? "desc" : "asc";
        }

        return (sortBy, sortDirection);
    }

    private async Task OpenSocketDetails(StationDto station)
    {
        selectedStationForSockets = station;
        await socketDetailsModal.ShowAsync();
    }

    private async Task CloseSocketModal() => await socketDetailsModal.HideAsync();

    private async Task ExportToExcel()
    {
        if (!allCurrentData.Any()) return;
        var rows = allCurrentData.Select(s => string.Join(",", new[]
        {
            EscapeCsv(s.StationNumber), EscapeCsv(s.StationName), EscapeCsv(s.Brand), EscapeCsv(s.OperatorNetwork),
            EscapeCsv(s.OperatorStation), EscapeCsv(s.ServiceType), s.AddedDate.ToString("yyyy-MM-dd"), s.SocketCount.ToString(), s.TotalPower.ToString(),
            EscapeCsv(s.Status), s.DeactivatedDate?.ToString("yyyy-MM-dd") ?? "", EscapeCsv(s.Address)
        }));
        var csv = "Station No,Station Name,Brand,Network,Company,Service Type,Added Date,Sockets,kW,Status,Passive Date,Address\n" + string.Join("\n", rows);
        await JsRuntime.InvokeVoidAsync("eval", $"const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent({System.Text.Json.JsonSerializer.Serialize(csv)});a.download='stations.csv';a.click();");
    }

    private static string EscapeCsv(string? value) => $"\"{(value ?? string.Empty).Replace("\"", "\"\"")}\"";

    public class PagedResult<T>
    {
        public List<T> Data { get; set; } = new();
        public int TotalCount { get; set; }
    }
}
