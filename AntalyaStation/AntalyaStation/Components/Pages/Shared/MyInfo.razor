@page "/profile/my-info"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Net.Http.Json
@using AntalyaStation.API.DTOs
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject IJSRuntime JsRuntime
@inject AuthenticationStateProvider AuthStateProvider

<style>
    .mi-header {
        background: linear-gradient(135deg, #0d47a1 0%, #1976d2 60%, #00acc1 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 8px 24px rgba(13,71,161,0.2);
    }
    .mi-header h3 { font-weight: 800; margin-bottom: 4px; }
    .mi-header p { opacity: 0.9; margin-bottom: 0; font-size: 14px; }

    .mi-card { border-radius: 14px; border: none; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .mi-card .form-label { font-size: 12px; font-weight: 700; color: #495057; text-transform: uppercase; letter-spacing: 0.3px; }

    .mi-avatar {
        width: 84px; height: 84px; border-radius: 50%;
        background: linear-gradient(135deg, #1976d2, #00acc1);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; font-weight: 800; color: #fff;
    }
</style>

<div class="container-fluid mt-3" style="font-size: 13px; max-width: 700px;">

    <div class="mi-header">
        <h3><i class="bi bi-person-badge-fill"></i> My Info</h3>
        <p>View and update your personal account information.</p>
    </div>

    @if (_isLoading)
    {
    <div class="text-center py-5">
        <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
    </div>
    }
    else
    {
    <div class="card mi-card">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="mi-avatar">@GetInitial()</div>
                <div>
                    <div class="fw-bold fs-5">@_profile?.FullName</div>
                    <span class="badge bg-primary-subtle text-primary fw-semibold">@_profile?.Role</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_feedback))
            {
            <div class="alert @(_isError ? "alert-danger" : "alert-success") py-2 small mb-3">@_feedback</div>
            }

            <EditForm Model="_form" OnValidSubmit="SaveProfile">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label d-block mb-1">Username</label>
                        <InputText class="form-control" @bind-Value="_form.Username" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label d-block mb-1">Full Name</label>
                        <InputText class="form-control" @bind-Value="_form.FullName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label d-block mb-1">Email</label>
                        <InputText class="form-control" @bind-Value="_form.Email" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label d-block mb-1">Phone Number</label>
                        <InputText class="form-control" @bind-Value="_form.PhoneNumber" placeholder="+90 5xx xxx xx xx" />
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary fw-semibold px-4" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Save Changes
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
    }
</div>

@code {
private UserProfileDto? _profile;
private UpdateProfileDto _form = new();
private bool _isLoading = true;
private bool _isSaving = false;
private string _feedback = "";
private bool _isError = false;

protected override async Task OnInitializedAsync()
{
await LoadProfile();
}

private async Task LoadProfile()
{
_isLoading = true;
try
{
_profile = await Http.GetFromJsonAsync<UserProfileDto>("api/auth/me");
if (_profile != null)
{
_form = new UpdateProfileDto
{
Username = _profile.Username,
FullName = _profile.FullName,
Email = _profile.Email,
PhoneNumber = _profile.PhoneNumber
};
}
}
catch (Exception ex)
{
_feedback = $"Failed to load profile: {ex.Message}";
_isError = true;
}
_isLoading = false;
}

private string GetInitial() =>
string.IsNullOrWhiteSpace(_profile?.FullName) ? "?" : _profile.FullName.Trim()[0].ToString().ToUpper();

private async Task SaveProfile()
{
_isSaving = true;
_feedback = "";
try
{
var response = await Http.PutAsJsonAsync("api/auth/profile", _form);
if (response.IsSuccessStatusCode)
{
var result = await response.Content.ReadFromJsonAsync<UpdateResultDto>();

// 🟢 Kullanıcı adı değiştiyse yeni token'ı kaydedip auth state'i yeniliyoruz
if (result != null && !string.IsNullOrEmpty(result.Token))
{
await JsRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
if (AuthStateProvider is AntalyaStation.Client.Handlers.CustomAuthStateProvider customProvider)
{
await customProvider.MarkUserAsAuthenticated(result.Token);
}
}

_feedback = "Profile updated successfully.";
_isError = false;
await LoadProfile();
}
else
{
var rawError = await response.Content.ReadAsStringAsync();
_feedback = $"Update failed: {rawError}";
_isError = true;
}
}
catch (Exception ex)
{
_feedback = $"Connection error: {ex.Message}";
_isError = true;
}
_isSaving = false;
}

public class UpdateResultDto
{
public string Message { get; set; } = string.Empty;
public string? Token { get; set; }
}
}