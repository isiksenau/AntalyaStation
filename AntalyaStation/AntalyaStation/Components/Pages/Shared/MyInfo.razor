@page "/profile/my-info"
@using System.Net.Http.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject IJSRuntime JsRuntime

<style>
    .ps-header {
        background: linear-gradient(135deg, #0d47a1 0%, #1976d2 60%, #00acc1 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: #fff;
        margin-bottom: 24px;
        box-shadow: 0 8px 24px rgba(13,71,161,0.2);
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .ps-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    .ps-header h3 { font-weight: 800; margin-bottom: 2px; }
    .ps-header p { opacity: 0.9; margin-bottom: 0; font-size: 14px; }

    .ps-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #eef0f2;
        box-shadow: 0 4px 16px rgba(0,0,0,0.05);
        padding: 28px;
        max-width: 640px;
    }
    .ps-card-title {
        font-weight: 700;
        font-size: 16px;
        color: #212529;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ps-readonly-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f1f3f5;
        font-size: 14px;
    }
    .ps-readonly-row span:first-child { color: #6c757d; }
    .ps-readonly-row span:last-child { font-weight: 600; color: #212529; }

    .ps-alert {
        margin-top: 16px;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }
    .ps-alert-success { background: #e6f7ee; color: #16794e; border: 1px solid #b7ecd0; }
    .ps-alert-error { background: #fdeaea; color: #c0392b; border: 1px solid #f3c1bc; }
</style>

<div class="container-fluid py-3">

    <div class="ps-header">
        <div class="ps-header-icon"><i class="bi bi-person-circle"></i></div>
        <div>
            <h3>My Info</h3>
            <p>View and update your basic profile details.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-muted"><span class="spinner-border spinner-border-sm me-2"></span> Loading your profile...</div>
    }
    else if (profile == null)
    {
        <div class="ps-alert ps-alert-error"><i class="bi bi-exclamation-triangle-fill"></i> Could not load your profile. Please try again later.</div>
    }
    else
    {
        <div class="ps-card">
            <div class="ps-card-title"><i class="bi bi-info-circle text-primary"></i> Account Details</div>

            <div class="ps-readonly-row">
                <span>Username</span>
                <span>@profile.Username</span>
            </div>
            <div class="ps-readonly-row">
                <span>Role</span>
                <span>@profile.Role</span>
            </div>
            <div class="ps-readonly-row mb-3">
                <span>Member since</span>
                <span>@profile.CreatedDate.ToString("dd MMM yyyy")</span>
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted mb-1">Full Name</label>
                <input class="form-control" @bind="editFullName" placeholder="Enter your full name" />
            </div>

            <div class="mb-3">
                <label class="form-label small text-muted mb-1">Email</label>
                <input type="email" class="form-control" @bind="editEmail" placeholder="Enter your email address" />
            </div>

            <button class="btn btn-primary fw-semibold" @onclick="SaveProfile" disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span><i class="bi bi-check2 me-1"></i> Save Changes</span>
                }
            </button>

            @if (!string.IsNullOrEmpty(feedback))
            {
                <div class="ps-alert @(isSuccess ? "ps-alert-success" : "ps-alert-error")">
                    <i class="bi @(isSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                    <span>@feedback</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private UserProfileDto? profile;
    private bool isLoading = true;
    private bool isSaving = false;

    private string editFullName = "";
    private string editEmail = "";

    private string? feedback;
    private bool isSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private async Task EnsureAuthHeader()
    {
        try
        {
            var token = await JsRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
        }
        catch
        {
            // JS interop not ready yet (prerender) — request will simply go out without a token.
        }
    }

    private async Task LoadProfile()
    {
        isLoading = true;
        try
        {
            await EnsureAuthHeader();
            profile = await Http.GetFromJsonAsync<UserProfileDto>("api/auth/me");
            if (profile != null)
            {
                editFullName = profile.FullName;
                editEmail = profile.Email;
            }
        }
        catch
        {
            profile = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfile()
    {
        isSaving = true;
        feedback = null;
        try
        {
            await EnsureAuthHeader();
            var response = await Http.PutAsJsonAsync("api/auth/profile", new
            {
                FullName = editFullName,
                Email = editEmail
            });

            if (response.IsSuccessStatusCode)
            {
                feedback = "Your profile was updated successfully.";
                isSuccess = true;
                await LoadProfile();
            }
            else
            {
                feedback = $"Update failed (HTTP {(int)response.StatusCode}).";
                isSuccess = false;
            }
        }
        catch (Exception ex)
        {
            feedback = $"Something went wrong: {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            isSaving = false;
        }
    }

    public class UserProfileDto
    {
        public string Username { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public DateTime CreatedDate { get; set; }
    }
}
