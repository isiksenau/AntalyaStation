@page "/profile/change-password"
@using System.Net.Http.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject IJSRuntime JsRuntime

<style>
    .ps-header {
        background: linear-gradient(135deg, #0d47a1 0%, #1976d2 60%, #00acc1 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: #fff;
        margin-bottom: 24px;
        box-shadow: 0 8px 24px rgba(13,71,161,0.2);
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .ps-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    .ps-header h3 { font-weight: 800; margin-bottom: 2px; }
    .ps-header p { opacity: 0.9; margin-bottom: 0; font-size: 14px; }

    .ps-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #eef0f2;
        box-shadow: 0 4px 16px rgba(0,0,0,0.05);
        padding: 28px;
        max-width: 520px;
    }
    .ps-card-title {
        font-weight: 700;
        font-size: 16px;
        color: #212529;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ps-card-subtitle {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 20px;
    }
    .ps-rule-list {
        font-size: 12px;
        color: #8a939c;
        margin: 6px 0 20px 0;
        padding-left: 18px;
    }

    .ps-alert {
        margin-top: 16px;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 13px;
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }
    .ps-alert-success { background: #e6f7ee; color: #16794e; border: 1px solid #b7ecd0; }
    .ps-alert-error { background: #fdeaea; color: #c0392b; border: 1px solid #f3c1bc; }
</style>

<div class="container-fluid py-3">

    <div class="ps-header">
        <div class="ps-header-icon"><i class="bi bi-shield-lock-fill"></i></div>
        <div>
            <h3>Change Password</h3>
            <p>Update the password used to sign in to your account.</p>
        </div>
    </div>

    <div class="ps-card">
        <div class="ps-card-title"><i class="bi bi-key text-primary"></i> Update Password</div>
        <div class="ps-card-subtitle">Enter your current password, then choose a new one.</div>

        <div class="mb-3">
            <label class="form-label small text-muted mb-1">Current Password</label>
            <input type="password" class="form-control" @bind="currentPassword" placeholder="Enter current password" />
        </div>

        <div class="mb-3">
            <label class="form-label small text-muted mb-1">New Password</label>
            <input type="password" class="form-control" @bind="newPassword" placeholder="Enter new password" />
        </div>

        <div class="mb-2">
            <label class="form-label small text-muted mb-1">Confirm New Password</label>
            <input type="password" class="form-control" @bind="confirmPassword" placeholder="Re-enter new password" />
        </div>

        <ul class="ps-rule-list">
            <li>At least 6 characters long</li>
            <li>Must match the confirmation field</li>
        </ul>

        <button class="btn btn-primary fw-semibold" @onclick="SubmitPasswordChange" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Updating...</span>
            }
            else
            {
                <span><i class="bi bi-shield-check me-1"></i> Update Password</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(feedback))
        {
            <div class="ps-alert @(isSuccess ? "ps-alert-success" : "ps-alert-error")">
                <i class="bi @(isSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                <span>@feedback</span>
            </div>
        }
    </div>
</div>

@code {
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";

    private bool isSaving = false;
    private string? feedback;
    private bool isSuccess;

    private async Task EnsureAuthHeader()
    {
        try
        {
            var token = await JsRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
        }
        catch
        {
            // JS interop not ready yet (prerender) — request will simply go out without a token.
        }
    }

    private async Task SubmitPasswordChange()
    {
        feedback = null;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            feedback = "Please fill in all fields.";
            isSuccess = false;
            return;
        }

        if (newPassword != confirmPassword)
        {
            feedback = "New password and confirmation do not match.";
            isSuccess = false;
            return;
        }

        if (newPassword.Length < 6)
        {
            feedback = "New password must be at least 6 characters long.";
            isSuccess = false;
            return;
        }

        isSaving = true;
        try
        {
            await EnsureAuthHeader();
            var response = await Http.PostAsJsonAsync("api/auth/change-password", new
            {
                CurrentPassword = currentPassword,
                NewPassword = newPassword,
                ConfirmPassword = confirmPassword
            });

            if (response.IsSuccessStatusCode)
            {
                feedback = "Your password was changed successfully.";
                isSuccess = true;
                currentPassword = "";
                newPassword = "";
                confirmPassword = "";
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                feedback = string.IsNullOrWhiteSpace(errorBody)
                    ? $"Password change failed (HTTP {(int)response.StatusCode})."
                    : errorBody;
                isSuccess = false;
            }
        }
        catch (Exception ex)
        {
            feedback = $"Something went wrong: {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            isSaving = false;
        }
    }
}
