@page "/admin/control-panel"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Net.Http.Json
@using AntalyaStation.API.DTOs
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@attribute [Authorize(Policy = "Permission.SystemConsole")]



<style>
    .sc-header {
        background: linear-gradient(135deg, #263238 0%, #37474f 60%, #455a64 100%);
        border-radius: 16px;
        padding: 28px 32px;
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 8px 24px rgba(38,50,56,0.25);
    }
    .sc-header h3 { font-weight: 800; margin-bottom: 4px; }
    .sc-header p { opacity: 0.85; margin-bottom: 0; font-size: 14px; }

    .sc-card { border-radius: 14px; border: none; box-shadow: 0 4px 16px rgba(0,0,0,0.06); height: 100%; }
    .sc-stat-icon { font-size: 1.8rem; opacity: 0.85; }
    .sc-stat-value { font-size: 1.8rem; font-weight: 800; }
    .sc-stat-label { font-size: 12px; color: #6c757d; text-transform: uppercase; letter-spacing: 0.4px; font-weight: 700; }

    .sc-status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
    .sc-status-ok { background: #28a745; box-shadow: 0 0 6px #28a745; }

    .sc-maintenance-row { display: flex; align-items: flex-start; gap: 14px; flex-wrap: wrap; padding: 12px 0; border-bottom: 1px solid #f1f3f5; }
    .sc-maintenance-row:last-child { border-bottom: none; }
    .sc-maintenance-desc { font-size: 12.5px; color: #6c757d; max-width: 460px; }

    .sc-progress-bar { height: 6px; background: #e9ecef; border-radius: 4px; overflow: hidden; margin-top: 8px; }
    .sc-progress-bar-fill { height: 100%; background: linear-gradient(90deg, #2563eb, #1976d2); transition: width 0.3s ease; }
</style>

<div class="container-fluid mt-3" style="font-size: 13px;">

    <div class="sc-header">
        <h3><i class="bi bi-hdd-network-fill"></i> System Console</h3>
        <p>Live overview of platform health, data volume, and system status.</p>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card sc-card p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-ev-station text-primary sc-stat-icon"></i>
                    </div>
                    <div class="sc-stat-value">@_stats?.TotalActiveStations</div>
                    <div class="sc-stat-label">Active Stations</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card sc-card p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-archive text-secondary sc-stat-icon"></i>
                    </div>
                    <div class="sc-stat-value">@_systemStats?.InactiveStations</div>
                    <div class="sc-stat-label">Passive Stations</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card sc-card p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-lightning-charge text-warning sc-stat-icon"></i>
                    </div>
                    <div class="sc-stat-value">@_stats?.TotalPowerCapacity.ToString("N0")</div>
                    <div class="sc-stat-label">Total Power (kW)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card sc-card p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-people-fill text-info sc-stat-icon"></i>
                    </div>
                    <div class="sc-stat-value">@_userCount</div>
                    <div class="sc-stat-label">Registered Users</div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card sc-card p-3">
                    <h6 class="fw-bold mb-3"><i class="bi bi-server me-1"></i> Service Status</h6>
                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                        <span class="text-muted">API Layer</span>
                        <span><span class="sc-status-dot sc-status-ok"></span>Online</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                        <span class="text-muted">Database Connection</span>
                        <span><span class="sc-status-dot sc-status-ok"></span>Connected</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Authentication Service</span>
                        <span><span class="sc-status-dot sc-status-ok"></span>Operational</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card sc-card p-3">
                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-1"></i> Environment</h6>
                    <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                        <span class="text-muted">Application</span>
                        <span class="fw-semibold">AntalyaStation Platform</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                        <span class="text-muted">Environment</span>
                        <span class="fw-semibold">Development</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Report Generated</span>
                        <span class="fw-semibold">@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 🆕 MAINTENANCE ACTIONS -->
        <div class="row g-3 mt-1">
            <div class="col-12">
                <div class="card sc-card p-3">
                    <h6 class="fw-bold mb-1"><i class="bi bi-tools me-1"></i> Maintenance Actions</h6>
                    <p class="text-muted small mb-2">Run housekeeping tasks against the station repository.</p>

                    <div class="sc-maintenance-row">
                        <button class="btn btn-outline-primary btn-sm fw-semibold" style="min-width: 220px;" @onclick="RunDataCleanup" disabled="@_isCleaning">
                            @if (_isCleaning)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            <i class="bi bi-wrench-adjustable-circle me-1"></i> Repair Station Data
                        </button>
                        <span class="sc-maintenance-desc">
                            Recalculates power totals, normalizes station names, and removes invalid socket entries
                            left over from malformed Excel imports (e.g. a mis-parsed header row saved as a socket).
                        </span>
                    </div>

                    <div class="sc-maintenance-row" style="width: 100%;">
                        <div style="min-width: 220px;">
                            <button class="btn btn-outline-primary btn-sm fw-semibold w-100" @onclick="RunResolveLocations" disabled="@_isResolvingLocations">
                                @if (_isResolvingLocations)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-geo-alt-fill me-1"></i> Resolve Missing Locations
                            </button>
                        </div>
                        <div style="flex: 1; min-width: 260px;">
                            <span class="sc-maintenance-desc">
                                Looks up real coordinates for stations with no saved location and stores them
                                permanently. Runs as a background job on the server — you can safely navigate away
                                or close this tab, it keeps running and picks up where it left off if you come back.
                            </span>
                            @if (_geoTotalPending > 0)
                            {
                                <div class="sc-progress-bar">
                                    <div class="sc-progress-bar-fill" style="width:@GetGeoProgressPercent()%"></div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_cleanupFeedback))
                    {
                        <div class="alert alert-info py-2 mt-2 mb-0 small">@_cleanupFeedback</div>
                    }
                    @if (!string.IsNullOrEmpty(_resolveLocationsFeedback))
                    {
                        <div class="alert alert-info py-2 mt-2 mb-0 small">@_resolveLocationsFeedback</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardStatsDto? _stats;
    private int _userCount = 0;
    private SystemStatsDto? _systemStats;
    private bool _isLoading = true;

    private bool _isCleaning = false;
    private string _cleanupFeedback = "";

    private bool _isResolvingLocations = false;
    private string _resolveLocationsFeedback = "";
    private int _geoTotalPending = 0;
    private int _geoResolved = 0;
    private int _geoFailed = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await Http.GetFromJsonAsync<DashboardStatsDto>("api/stations/dashboard-stats");
            _systemStats = await Http.GetFromJsonAsync<SystemStatsDto>("api/UserManagement/system-stats");
            var users = await Http.GetFromJsonAsync<List<AdminUserListItemDto>>("api/users");
            _userCount = users?.Count ?? 0;

            // 🟢 Sayfa yeniden açıldığında sunucuda hâlâ çalışan bir job varsa
            // (ör. sekmeyi kapatıp geri geldiyse) durumu ve ilerlemeyi geri yükle.
            var status = await Http.GetFromJsonAsync<GeoJobStatus>("api/stations/resolve-locations/status");
            if (status != null)
            {
                _geoTotalPending = status.TotalPending;
                _geoResolved = status.Resolved;
                _geoFailed = status.Failed;
                if (status.IsRunning)
                {
                    _resolveLocationsFeedback = status.Message;
                    _isResolvingLocations = true;
                    _ = PollGeocodingStatusAsync();
                }
            }
        }
        catch { /* silent — panel widgets just show blank */ }
        _isLoading = false;
    }

    private async Task RunDataCleanup()
    {
        _isCleaning = true;
        _cleanupFeedback = "";
        try
        {
            var response = await Http.PostAsync("api/stations/cleanup-data", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                _cleanupFeedback = result != null && result.ContainsKey("message")
                    ? result["message"]
                    : "Cleanup completed.";

                _stats = await Http.GetFromJsonAsync<DashboardStatsDto>("api/stations/dashboard-stats");
            }
            else
            {
                _cleanupFeedback = $"Cleanup failed (HTTP {(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            _cleanupFeedback = $"Error: {ex.Message}";
        }
        finally
        {
            _isCleaning = false;
        }
    }

    // 🟢 Artık tek bir uzun HTTP isteği YOK. Sadece "başlat" (anında döner) ve
    // ardından her 2 saniyede bir çok küçük/hızlı bir "durum sorgula" isteği.
    // Timeout riski tamamen ortadan kalkar, iş kaç istasyon olursa olsun sunucuda devam eder.
    private async Task RunResolveLocations()
    {
        _resolveLocationsFeedback = "Starting geocoding job...";
        _isResolvingLocations = true;
        StateHasChanged();

        try
        {
            var startResponse = await Http.PostAsync("api/stations/resolve-locations/start", null);
            if (!startResponse.IsSuccessStatusCode)
            {
                _resolveLocationsFeedback = $"Could not start job (HTTP {(int)startResponse.StatusCode}).";
                _isResolvingLocations = false;
                return;
            }

            await PollGeocodingStatusAsync();
        }
        catch (Exception ex)
        {
            _resolveLocationsFeedback = $"Error: {ex.Message}";
            _isResolvingLocations = false;
        }
    }

    private async Task PollGeocodingStatusAsync()
    {
        try
        {
            while (true)
            {
                await Task.Delay(2000);

                var status = await Http.GetFromJsonAsync<GeoJobStatus>("api/stations/resolve-locations/status");
                if (status == null) break;

                _geoTotalPending = status.TotalPending;
                _geoResolved = status.Resolved;
                _geoFailed = status.Failed;
                _resolveLocationsFeedback = status.Message;
                _isResolvingLocations = status.IsRunning;
                await InvokeAsync(StateHasChanged);

                if (!status.IsRunning)
                    break;
            }

            _stats = await Http.GetFromJsonAsync<DashboardStatsDto>("api/stations/dashboard-stats");
        }
        catch (Exception ex)
        {
            _resolveLocationsFeedback = $"Error while checking progress: {ex.Message}";
        }
        finally
        {
            _isResolvingLocations = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private int GetGeoProgressPercent()
    {
        if (_geoTotalPending <= 0) return 0;
        var done = _geoResolved + _geoFailed;
        return (int)Math.Min(100, Math.Round(done * 100.0 / _geoTotalPending));
    }

    private class GeoJobStatus
    {
        public bool IsRunning { get; set; }
        public int TotalPending { get; set; }
        public int Resolved { get; set; }
        public int Failed { get; set; }
        public int Remaining { get; set; }
        public string Message { get; set; } = "";
    }
}
