@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            <div class="page">
                <div class="sidebar">
                    <NavMenu />
                </div>

                <main>
                    <div class="top-row px-4 d-flex justify-content-between align-items-center bg-light border-bottom">
                        <span class="text-secondary small">
                            <strong>Oturum:</strong> @context.User.Identity?.Name
                            (<span class="text-primary fw-bold">@context.User.FindFirst("role")?.Value</span>)
                        </span>
                        <button @onclick="Logout" class="btn btn-sm btn-outline-danger py-1">
                            <i class="bi bi-box-arrow-left me-1"></i>Güvenli Çıkış
                        </button>
                    </div>

                    <article class="content px-4 py-3">
                        @Body
                    </article>
                </main>
            </div>
        </Authorized>

        <!-- 🟢 DÜZELTME: Kullanıcı giriş yapmamışsa artık burada kart göstermek yerine
             tek, gerçek login sayfası olan /login'e yönlendiriyoruz. -->
        <NotAuthorized>
            @{
                Navigation.NavigateTo("/login", forceLoad: false);
            }
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

@code {
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;

    private async Task Logout()
    {
        var customProvider = (AntalyaStation.Client.Handlers.CustomAuthStateProvider)AuthStateProvider;
        await customProvider.MarkUserAsLoggedOut();
    }
}